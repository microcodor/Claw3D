// 任务类型和优先级配置（固定顺序）
// 10个网络安全话题，全部为文章类型
const TASK_CONFIGS = [
  { type: 'article' as const, priority: 5 as const },  // 1. 勒索软件攻击
  { type: 'article' as const, priority: 5 as const },  // 2. AI钓鱼攻击
  { type: 'article' as const, priority: 4 as const },  // 3. 零信任架构
  { type: 'article' as const, priority: 5 as const },  // 4. 供应链攻击
  { type: 'article' as const, priority: 4 as const },  // 5. 内部威胁检测
  { type: 'article' as const, priority: 5 as const },  // 6. 云安全
  { type: 'article' as const, priority: 4 as const },  // 7. API安全
  { type: 'article' as const, priority: 4 as const },  // 8. 容器安全
  { type: 'article' as const, priority: 4 as const },  // 9. 移动应用安全
  { type: 'article' as const, priority: 5 as const },  // 10. IoT设备安全
];

// 自动任务生成器（使用 V1 数据，固定顺序）
// 使用闭包来保持 messageIndex 的状态
const createTaskGenerator = () => {
  let messageIndex = 0;
  
  return (): CreationTask => {
    // 从 V1 Mock 数据中按顺序获取选题
    const index = messageIndex % MOCK_MESSAGES.length;
    const message = MOCK_MESSAGES[index];
    const config = TASK_CONFIGS[index];
    
    messageIndex++;
    
    return {
      id: `task-${Date.now()}-${Math.random()}`,
      title: message.user,
      type: config.type,
      status: 'pending',
      priority: config.priority,
      source: 'custom',
      createdAt: new Date(),
      prompt: message.user,
      // 存储对应的生成结果
      metadata: {
        mockOutput: message.assistant,
      },
    };
  };
};

const autoGenerateTask = createTaskGenerator();

// 生成 Mock 内容（使用 V1 数据）
function generateMockContent(task: CreationTask): string {
  // 如果任务有预设的 mock 输出，使用它
  if (task.metadata?.mockOutput) {
    return task.metadata.mockOutput;
  }
  
  // 否则使用默认模板
  return `# ${task.title}

这是一个自动生成的内容示例。

## 核心观点

基于当前热点和用户需求，我们提供以下分析和建议。

## 详细内容

内容正在生成中...`;
